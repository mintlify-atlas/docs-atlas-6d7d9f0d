{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Jarallax",
  "theme": "palm",
  "colors": {
    "primary": "#7c7c7c",
    "light": "#090909",
    "dark": "#c8c8c8"
  },
  "favicon": "https://media.brand.dev/c95c5745-ab0c-4cc2-9e20-eae69e9d2d2a.png",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/nk-o/jarallax"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nk-o/jarallax"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/basic-usage",
              "guides/video-backgrounds",
              "guides/advanced-options",
              "guides/events-and-methods"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/vanilla-javascript",
              "examples/react-nextjs",
              "examples/jquery"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api/options",
              "api/methods",
              "api/events",
              "api/video-extension"
            ]
          }
        ]
      }
    ]
  }
}
